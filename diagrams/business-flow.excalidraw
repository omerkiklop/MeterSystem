    {
      "id": "text_7", "type": "text",
      "x": 690, "y": 1110, "width": 340, "height": 280,
      "angle": 0, "strokeColor": "#1e1e2e", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid",
      "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null,
      "fontSize": 12, "fontFamily": 1, "lineHeight": 1.4,
      "text": "Redis · IReadingsCache / RedisReadingsCache\n─────────────────────────────────\nGetMeterIdAsync(meterNumber)\n  Key: meter:{meterNumber} → long?\n  TTL: 1 hour\nSetMeterIdAsync(meterNumber, meterId)\n  Key: meter:{meterNumber}\nIsReadingProcessedAsync(meterNumber, valueAt)\n  Key: reading:{n}:{unixMs} → bool\n  TTL: 24 hours\nMarkReadingProcessedAsync(meterNumber, valueAt)\n  Key: reading:{n}:{unixMs} = '1'\nFallback: log warning + continue if Redis unavailable",
      "textAlign": "center", "verticalAlign": "middle",
      "containerId": "rect_7",
      "originalText": "Redis · IReadingsCache / RedisReadingsCache\n─────────────────────────────────\nGetMeterIdAsync(meterNumber)\n  Key: meter:{meterNumber} → long?\n  TTL: 1 hour\nSetMeterIdAsync(meterNumber, meterId)\n  Key: meter:{meterNumber}\nIsReadingProcessedAsync(meterNumber, valueAt)\n  Key: reading:{n}:{unixMs} → bool\n  TTL: 24 hours\nMarkReadingProcessedAsync(meterNumber, valueAt)\n  Key: reading:{n}:{unixMs} = '1'\nFallback: log warning + continue if Redis unavailable"
    },

